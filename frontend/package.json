{
  "name": "harc-system",
  "version": "1.0.0",
  "private": true,
  "description": "H.A.R.C. System - Hydro Automated Retro Cannon (Ubuntu Desktop Application)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd ../backend && python3 run.py",
    "dev:frontend": "./node_modules/.bin/next dev --turbopack -p 9002",
    "electron:start": "electron . --no-sandbox",
    "electron:dev": "NODE_ENV=development electron . --no-sandbox",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "NODE_ENV=production next build",
    "build:electron": "electron-builder --linux",
    "install:all": "npm run install:backend && npm install",
    "install:backend": "cd ../backend && (./setup.sh || (python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt))",
    "start": "electron . --no-sandbox",
    "package": "electron-builder --dir",
    "dist": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb",
    "dist:snap": "electron-builder --linux snap",
    "install-run": "bash ../install-run.sh",
    "build-release": "bash ../build.sh"
  },
  "build": {
    "appId": "com.harc.system",
    "productName": "H.A.R.C. System",
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "../assets/icon.png"
    },
    "files": [
      "electron/**/*",
      "../backend/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json",
      "next.config.ts",
      "node_modules/**/*",
      "!../backend/venv/**/*",
      "!../backend/__pycache__/**/*",
      "!**/*.md",
      "!**/node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!venv/**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "lucide-react": "^0.475.0",
    "next": "15.3.3",
    "patch-package": "^8.0.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.8.0"
  }
}
